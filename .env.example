# ===========================================
# 科普助手·科科 — 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ===========================================

# ---------- DeepSeek API（默认提供商）----------
API_KEY=sk-your-deepseek-api-key
BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat
MAX_TOKENS=2048
TEMPERATURE=0.7

# ---------- DeepSeek 专用字段 ----------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------- OpenAI（可选，用于 GPT 系列模型）----------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- 自定义 OpenAI 兼容提供商（如通义千问 DashScope）----------
CUSTOM_API_KEY=
CUSTOM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------- 服务配置 ----------
HOST=0.0.0.0
PORT=8000
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./data/chatbot.db

# ---------- 语音识别 (ASR) ----------
ASR_MODEL=qwen3-asr-flash
ASR_LANGUAGE=zh

# ---------- 微信登录（可选）----------
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_WEB_APPID=
WECHAT_WEB_SECRET=
WECHAT_REDIRECT_URI=http://localhost:8000/wechat/callback.html

# ---------- 认证 ----------
TOKEN_SECRET=
TOKEN_EXPIRE_HOURS=72
